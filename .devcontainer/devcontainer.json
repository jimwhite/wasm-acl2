{
    "name": "Awesome Verified Coding Agents",
    "image": "ghcr.io/jimwhite/acl2-jupyter:latest",
    "containerEnv": {
        "JUPYTER_PORT": "8899",
        "RESTARTABLE": "yes",
        "USER": "jovyan",
        "ACL2_LISP": "sbcl",
        // Only use one ACL2 / SAVED_ACL2 per container.  
        // Updated the symlinks /opt/acl2/bin/acl2 and /home/acl2/saved_acl2 to point to the same ACL2 executable.
        "ACL2": "/opt/acl2/bin/acl2",
        "ACL2_HOME": "/home/acl2",
        "ACL2_SYSTEM_BOOKS": "/home/acl2/books"
    }
}